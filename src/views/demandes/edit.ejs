<!--
  demandes/edit.ejs
  ------------------
  Formulaire de modification d'une demande de produit (particuliers uniquement).
  Accessible uniquement au propriétaire de la demande.

  Variables reçues depuis demandes.controller.js > showEditDemande :
    - title    : "Modifier la demande"
    - activePage : "demandes"
    - demande  : Objet demande à modifier :
                 { id_demande, titre, description, produit_recherche,
                   quantite_souhaitee, unite, statut, created_at,
                   id_user_particulier }
    - error    : Message d'erreur (null si aucun)

  Comportement :
    - Les champs sont pré-remplis avec les données actuelles de la demande.
    - En cas d'erreur de validation, les champs contiennent les valeurs soumises.
    - Une zone de danger permet de supprimer définitivement la demande.
-->
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — B2CFarmer</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <%- include('../navbar') %>

    <main class="page form-page">
      <div class="form-card">

        <!-- En-tête du formulaire -->
        <div class="form-card-header">
          <span class="form-card-icon">✏️</span>
          <h1 class="form-card-title">Modifier la demande</h1>
          <p class="form-card-subtitle">
            Mettez à jour les informations de votre demande de produit.
          </p>
        </div>

        <!-- Message d'erreur -->
        <% if (error) { %>
          <div class="alert alert-error" role="alert">
            <span class="alert-icon">⚠️</span>
            <%= error %>
          </div>
        <% } %>

        <!-- Formulaire de modification -->
        <form action="/demandes/<%= demande.id_demande %>/edit" method="post" class="auth-form" novalidate>

          <fieldset class="form-fieldset">
            <legend class="form-legend">Votre recherche</legend>

            <!-- Titre de la demande -->
            <div class="form-group">
              <label for="titre" class="form-label">
                Titre de votre demande <span class="required">*</span>
              </label>
              <input
                type="text"
                id="titre"
                name="titre"
                class="form-input"
                value="<%= demande.titre || '' %>"
                placeholder="Ex: Je cherche des tomates bio en vrac"
                required
              />
            </div>

            <!-- Produit recherché + quantité + unité -->
            <div class="form-row">
              <div class="form-group">
                <label for="produit_recherche" class="form-label">
                  Produit recherché <span class="required">*</span>
                </label>
                <input
                  type="text"
                  id="produit_recherche"
                  name="produit_recherche"
                  class="form-input"
                  value="<%= demande.produit_recherche || '' %>"
                  placeholder="Ex: Tomates cerises bio"
                  required
                />
              </div>

              <div class="form-group form-group-small">
                <label for="quantite_souhaitee" class="form-label">Quantité souhaitée</label>
                <input
                  type="number"
                  id="quantite_souhaitee"
                  name="quantite_souhaitee"
                  class="form-input"
                  value="<%= demande.quantite_souhaitee || '' %>"
                  placeholder="Ex: 5"
                  min="0"
                  step="0.5"
                />
              </div>

              <div class="form-group form-group-small">
                <label for="unite" class="form-label">Unité</label>
                <select id="unite" name="unite" class="form-input form-select">
                  <option value="">— choisir —</option>
                  <option value="kg"       <%= demande.unite === 'kg'       ? 'selected' : '' %>>kg</option>
                  <option value="pièce"    <%= demande.unite === 'pièce'    ? 'selected' : '' %>>pièce</option>
                  <option value="litre"    <%= demande.unite === 'litre'    ? 'selected' : '' %>>litre</option>
                  <option value="botte"    <%= demande.unite === 'botte'    ? 'selected' : '' %>>botte</option>
                  <option value="douzaine" <%= demande.unite === 'douzaine' ? 'selected' : '' %>>douzaine</option>
                </select>
              </div>
            </div>

            <!-- Description libre -->
            <div class="form-group">
              <label for="description" class="form-label">Description (optionnel)</label>
              <textarea
                id="description"
                name="description"
                class="form-input form-textarea"
                rows="4"
                placeholder="Précisez vos besoins : zone géographique souhaitée, qualité, mode de culture..."
              ><%= demande.description || '' %></textarea>
            </div>

          </fieldset>

          <!-- Boutons d'action -->
          <div class="form-actions-row">
            <button type="submit" class="btn btn-primary">
              Enregistrer les modifications
            </button>
            <a href="/demandes/<%= demande.id_demande %>" class="btn btn-secondary">
              Annuler
            </a>
          </div>

        </form>

        <!-- Zone de danger : suppression définitive -->
        <div class="danger-zone">
          <h3 class="danger-zone-title">⚠️ Supprimer cette demande</h3>
          <p class="danger-zone-text">
            Cette action est irréversible. La demande et toutes les réponses des agriculteurs
            seront définitivement supprimées.
          </p>
          <form
            action="/demandes/<%= demande.id_demande %>/delete"
            method="post"
            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette demande ? Cette action est irréversible.');"
          >
            <button type="submit" class="btn btn-danger">
              🗑️ Supprimer définitivement
            </button>
          </form>
        </div>

        <!-- Lien retour -->
        <div class="auth-footer">
          <p>
            <a href="/demandes/mes-demandes" class="link-accent">← Mes demandes</a>
          </p>
        </div>

      </div>
    </main>

    <footer class="site-footer">
      <p>&copy; 2025 B2CFarmer — Circuit court, liens forts</p>
    </footer>
  </body>
</html>
