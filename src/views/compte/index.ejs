<!--
  compte/index.ejs
  -----------------
  Page "Mon compte" — permet à l'utilisateur de consulter et modifier
  ses informations personnelles.

  Variables reçues depuis compte.controller.js :
    - title      : "Mon compte"
    - activePage : "compte"
    - userData   : Objet utilisateur complet :
                   { id_user, nom, prenom, email, telephone, role, created_at,
                     nom_exploitation, agri_description, siret, adresse,
                     code_postal, ville }
    - error      : Message d'erreur (null si aucune)
    - success    : true si le profil vient d'être mis à jour
-->
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — B2CFarmer</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <%- include('../navbar') %>

    <main class="page form-page">
      <div class="form-card">

        <!-- En-tête -->
        <div class="form-card-header">
          <h1 class="form-card-title">Mon compte</h1>
          <p class="form-card-subtitle">
            Consultez et modifiez vos informations personnelles.
          </p>
        </div>

        <!-- Rôle et date d'inscription -->
        <div class="compte-info-bar">
          <span class="compte-role-badge">
            <% if (userData.role === 'AGRICULTEUR') { %>
              Agriculteur
            <% } else { %>
              Particulier
            <% } %>
          </span>
          <span class="compte-date">
            Membre depuis le <%= new Date(userData.created_at).toLocaleDateString('fr-FR') %>
          </span>
        </div>

        <!-- Message de succès -->
        <% if (success) { %>
          <div class="alert alert-success" role="alert">
            Vos informations ont été mises à jour avec succès !
          </div>
        <% } %>

        <!-- Message d'erreur -->
        <% if (error) { %>
          <div class="alert alert-error" role="alert">
            <%= error %>
          </div>
        <% } %>

        <!-- Formulaire de modification -->
        <form action="/mon-compte" method="post" class="auth-form" novalidate>

          <!-- ── Informations personnelles ──────────────────── -->
          <fieldset class="form-fieldset">
            <legend class="form-legend">Informations personnelles</legend>

            <div class="form-row">
              <div class="form-group">
                <label for="prenom" class="form-label">
                  Prénom <span class="required">*</span>
                </label>
                <input
                  type="text"
                  id="prenom"
                  name="prenom"
                  class="form-input"
                  value="<%= userData.prenom || '' %>"
                  placeholder="Jean"
                  required
                />
              </div>
              <div class="form-group">
                <label for="nom" class="form-label">
                  Nom <span class="required">*</span>
                </label>
                <input
                  type="text"
                  id="nom"
                  name="nom"
                  class="form-input"
                  value="<%= userData.nom || '' %>"
                  placeholder="Dupont"
                  required
                />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email" class="form-label">
                  Adresse e-mail <span class="required">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  value="<%= userData.email || '' %>"
                  placeholder="jean.dupont@email.fr"
                  required
                />
              </div>
              <div class="form-group">
                <label for="telephone" class="form-label">Téléphone</label>
                <input
                  type="tel"
                  id="telephone"
                  name="telephone"
                  class="form-input"
                  value="<%= userData.telephone || '' %>"
                  placeholder="06 12 34 56 78"
                />
              </div>
            </div>

          </fieldset>

          <!-- ── Profil exploitation (agriculteurs uniquement) ── -->
          <% if (userData.role === 'AGRICULTEUR') { %>
            <fieldset class="form-fieldset">
              <legend class="form-legend">Mon exploitation</legend>

              <div class="form-group">
                <label for="nom_exploitation" class="form-label">
                  Nom de l'exploitation <span class="required">*</span>
                </label>
                <input
                  type="text"
                  id="nom_exploitation"
                  name="nom_exploitation"
                  class="form-input"
                  value="<%= userData.nom_exploitation || '' %>"
                  placeholder="Ferme des Trois Chênes"
                  required
                />
              </div>

              <div class="form-group">
                <label for="agri_description" class="form-label">Description de l'exploitation</label>
                <textarea
                  id="agri_description"
                  name="agri_description"
                  class="form-input form-textarea"
                  rows="3"
                  placeholder="Présentez votre exploitation, vos valeurs, votre mode de culture..."
                ><%= userData.agri_description || '' %></textarea>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="adresse" class="form-label">
                    Adresse <span class="required">*</span>
                  </label>
                  <input
                    type="text"
                    id="adresse"
                    name="adresse"
                    class="form-input"
                    value="<%= userData.adresse || '' %>"
                    placeholder="12 chemin des Clos"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="siret" class="form-label">Numéro SIRET</label>
                  <input
                    type="text"
                    id="siret"
                    name="siret"
                    class="form-input"
                    value="<%= userData.siret || '' %>"
                    placeholder="14 chiffres"
                    maxlength="14"
                    inputmode="numeric"
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group form-group-small">
                  <label for="code_postal" class="form-label">
                    Code postal <span class="required">*</span>
                  </label>
                  <input
                    type="text"
                    id="code_postal"
                    name="code_postal"
                    class="form-input"
                    value="<%= userData.code_postal || '' %>"
                    placeholder="45000"
                    maxlength="5"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="ville" class="form-label">
                    Ville <span class="required">*</span>
                  </label>
                  <input
                    type="text"
                    id="ville"
                    name="ville"
                    class="form-input"
                    value="<%= userData.ville || '' %>"
                    placeholder="Orléans"
                    required
                  />
                </div>
              </div>

            </fieldset>
          <% } %>

          <!-- ── Changement de mot de passe (optionnel) ────── -->
          <fieldset class="form-fieldset">
            <legend class="form-legend">Changer le mot de passe</legend>

            <p class="form-hint">
              Laissez ces champs vides si vous ne souhaitez pas modifier votre mot de passe.
            </p>

            <div class="form-group">
              <label for="current_password" class="form-label">Mot de passe actuel</label>
              <div class="input-wrapper">
                <input
                  type="password"
                  id="current_password"
                  name="current_password"
                  class="form-input"
                  placeholder="Votre mot de passe actuel"
                  autocomplete="current-password"
                />
                <button type="button" class="input-eye-btn"
                        aria-label="Afficher le mot de passe"
                        onclick="togglePassword('current_password', this)">
                  Afficher
                </button>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="new_password" class="form-label">Nouveau mot de passe</label>
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="new_password"
                    name="new_password"
                    class="form-input"
                    placeholder="Min. 8 caractères"
                    autocomplete="new-password"
                  />
                  <button type="button" class="input-eye-btn"
                          aria-label="Afficher le mot de passe"
                          onclick="togglePassword('new_password', this)">
                    Afficher
                  </button>
                </div>
              </div>
              <div class="form-group">
                <label for="confirm_new_password" class="form-label">Confirmer</label>
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="confirm_new_password"
                    name="confirm_new_password"
                    class="form-input"
                    placeholder="Répétez le nouveau mot de passe"
                    autocomplete="new-password"
                  />
                  <button type="button" class="input-eye-btn"
                          aria-label="Afficher le mot de passe"
                          onclick="togglePassword('confirm_new_password', this)">
                    Afficher
                  </button>
                </div>
              </div>
            </div>

          </fieldset>

          <!-- Bouton de soumission -->
          <button type="submit" class="btn btn-primary btn-full">
            Enregistrer les modifications
          </button>

        </form>

        <!-- Lien retour -->
        <div class="auth-footer">
          <p>
            <a href="/" class="link-accent">← Retour à l'accueil</a>
          </p>
        </div>

      </div>
    </main>

    <footer class="site-footer">
      <p>&copy; 2025 B2CFarmer — Circuit court, liens forts</p>
    </footer>

    <script>
      /**
       * Afficher/masquer le mot de passe dans un champ.
       */
      function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        if (input.type === 'password') {
          input.type = 'text';
          btn.textContent = 'Masquer';
          btn.setAttribute('aria-label', 'Masquer le mot de passe');
        } else {
          input.type = 'password';
          btn.textContent = 'Afficher';
          btn.setAttribute('aria-label', 'Afficher le mot de passe');
        }
      }
    </script>

    <%- include("../speed-insights") %>
  </body>
</html>
