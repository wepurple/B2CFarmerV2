<!--
  offres/creer.ejs
  -----------------
  Formulaire de création d'une offre (agriculteurs uniquement).

  Variables reçues depuis offres.controller.js > showCreerOffre :
    - title      : "Déposer une offre"
    - activePage : "offres"
    - error      : Message d'erreur à afficher (null si aucune erreur)
    - formData   : Valeurs déjà saisies (pour ré-afficher en cas d'erreur)

  Particularités du formulaire :
    - Section "produits" dynamique : JavaScript permet d'ajouter/supprimer
      des lignes de produits sans recharger la page.
    - Les produits sont envoyés sous forme de tableaux :
      produit_libelle[], produit_unite[], produit_categorie[], produit_prix[], produit_qte[]
    - Le serveur les traite dans handleCreerOffre() du contrôleur.
-->
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> — B2CFarmer</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <%- include('../navbar') %>

    <main class="page form-page">
      <div class="form-card">

        <!-- En-tête du formulaire -->
        <div class="form-card-header">
          <span class="form-card-icon">🌾</span>
          <h1 class="form-card-title">Déposer une offre</h1>
          <p class="form-card-subtitle">
            Publiez vos produits disponibles pour que les particuliers puissent vous contacter.
          </p>
        </div>

        <!-- Affichage de l'erreur si présente -->
        <% if (error) { %>
          <div class="alert alert-error" role="alert">
            <span class="alert-icon">⚠️</span>
            <%= error %>
          </div>
        <% } %>

        <!-- Formulaire de création d'offre -->
        <form action="/offres/creer" method="post" class="auth-form" novalidate>

          <!-- ── Informations générales de l'offre ──────────── -->
          <fieldset class="form-fieldset">
            <legend class="form-legend">Informations de l'offre</legend>

            <!-- Titre -->
            <div class="form-group">
              <label for="titre" class="form-label">
                Titre de l'offre <span class="required">*</span>
              </label>
              <input
                type="text"
                id="titre"
                name="titre"
                class="form-input"
                value="<%= formData.titre || '' %>"
                placeholder="Ex: Panier de légumes de saison"
                required
              />
            </div>

            <!-- Description -->
            <div class="form-group">
              <label for="description" class="form-label">Description</label>
              <textarea
                id="description"
                name="description"
                class="form-input form-textarea"
                rows="4"
                placeholder="Décrivez votre offre : origine des produits, conditions de retrait, etc."
              ><%= formData.description || '' %></textarea>
            </div>

            <!-- Dates de disponibilité -->
            <div class="form-row">
              <div class="form-group">
                <label for="date_debut" class="form-label">Date de début</label>
                <input
                  type="date"
                  id="date_debut"
                  name="date_debut"
                  class="form-input"
                  value="<%= formData.date_debut || '' %>"
                />
              </div>
              <div class="form-group">
                <label for="date_fin" class="form-label">Date de fin</label>
                <input
                  type="date"
                  id="date_fin"
                  name="date_fin"
                  class="form-input"
                  value="<%= formData.date_fin || '' %>"
                />
              </div>
            </div>

          </fieldset>


          <!-- ── Produits de l'offre ─────────────────────────
               Section dynamique : l'agriculteur peut ajouter
               autant de produits qu'il le souhaite.
               JavaScript gère l'ajout/suppression de lignes.
          ─────────────────────────────────────────────────── -->
          <fieldset class="form-fieldset" id="produits-fieldset">
            <legend class="form-legend">
              Produits proposés <span class="required">*</span>
            </legend>

            <p class="form-hint">
              Ajoutez au moins un produit avec son prix et sa quantité disponible.
            </p>

            <!-- Conteneur des lignes de produit (manipulé par JS) -->
            <div id="produits-container">
              <!-- La première ligne est toujours présente par défaut -->
              <div class="produit-row" id="produit-row-0">
                <div class="produit-row-fields">

                  <!-- Libellé du produit -->
                  <div class="form-group">
                    <label class="form-label">
                      Produit <span class="required">*</span>
                    </label>
                    <input
                      type="text"
                      name="produit_libelle[]"
                      class="form-input"
                      placeholder="Ex: Tomates cerises"
                      required
                    />
                  </div>

                  <!-- Unité de mesure -->
                  <div class="form-group form-group-small">
                    <label class="form-label">Unité <span class="required">*</span></label>
                    <select name="produit_unite[]" class="form-input form-select" required>
                      <option value="kg">kg</option>
                      <option value="pièce">pièce</option>
                      <option value="litre">litre</option>
                      <option value="botte">botte</option>
                      <option value="douzaine">douzaine</option>
                      <option value="sac">sac</option>
                    </select>
                  </div>

                  <!-- Catégorie -->
                  <div class="form-group">
                    <label class="form-label">Catégorie</label>
                    <select name="produit_categorie[]" class="form-input form-select">
                      <option value="légume">Légume</option>
                      <option value="fruit">Fruit</option>
                      <option value="viande">Viande</option>
                      <option value="produit laitier">Produit laitier</option>
                      <option value="œufs">Œufs</option>
                      <option value="céréale">Céréale</option>
                      <option value="autre">Autre</option>
                    </select>
                  </div>

                  <!-- Prix unitaire -->
                  <div class="form-group form-group-small">
                    <label class="form-label">
                      Prix (€) <span class="required">*</span>
                    </label>
                    <input
                      type="number"
                      name="produit_prix[]"
                      class="form-input"
                      placeholder="3.50"
                      min="0"
                      step="0.01"
                      required
                    />
                  </div>

                  <!-- Quantité disponible -->
                  <div class="form-group form-group-small">
                    <label class="form-label">
                      Quantité <span class="required">*</span>
                    </label>
                    <input
                      type="number"
                      name="produit_qte[]"
                      class="form-input"
                      placeholder="50"
                      min="0"
                      step="0.5"
                      required
                    />
                  </div>

                </div>
                <!-- Pas de bouton "supprimer" sur la première ligne (toujours requise) -->
              </div>
            </div>

            <!-- Bouton pour ajouter une ligne produit -->
            <button type="button" class="btn-add-produit" onclick="ajouterProduit()">
              + Ajouter un produit
            </button>

          </fieldset>

          <!-- Bouton de soumission -->
          <button type="submit" class="btn btn-primary btn-full">
            Publier l'offre
          </button>

        </form>

        <!-- Lien vers la liste des offres -->
        <div class="auth-footer">
          <p>
            <a href="/offres/mes-offres" class="link-accent">← Retour à mes offres</a>
          </p>
        </div>

      </div>
    </main>

    <footer class="site-footer">
      <p>&copy; 2025 B2CFarmer — Circuit court, liens forts</p>
    </footer>

    <script>
      /**
       * Compteur pour donner des ids uniques à chaque ligne produit ajoutée.
       * On commence à 1 car la ligne 0 est déjà présente dans le HTML.
       */
      let compteurLigne = 1;

      /**
       * ajouterProduit
       * ---------------
       * Crée dynamiquement une nouvelle ligne de produit dans le formulaire.
       * Appelée quand l'utilisateur clique sur "+ Ajouter un produit".
       */
      function ajouterProduit() {
        const container = document.getElementById('produits-container');
        const id        = compteurLigne++;

        // On crée le HTML de la nouvelle ligne
        // innerHTML permet d'insérer directement du HTML en tant que string
        const div = document.createElement('div');
        div.className = 'produit-row';
        div.id        = `produit-row-${id}`;

        div.innerHTML = `
          <div class="produit-row-fields">
            <div class="form-group">
              <label class="form-label">Produit <span class="required">*</span></label>
              <input type="text" name="produit_libelle[]" class="form-input"
                     placeholder="Ex: Pommes" required />
            </div>
            <div class="form-group form-group-small">
              <label class="form-label">Unité <span class="required">*</span></label>
              <select name="produit_unite[]" class="form-input form-select" required>
                <option value="kg">kg</option>
                <option value="pièce">pièce</option>
                <option value="litre">litre</option>
                <option value="botte">botte</option>
                <option value="douzaine">douzaine</option>
                <option value="sac">sac</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Catégorie</label>
              <select name="produit_categorie[]" class="form-input form-select">
                <option value="légume">Légume</option>
                <option value="fruit">Fruit</option>
                <option value="viande">Viande</option>
                <option value="produit laitier">Produit laitier</option>
                <option value="œufs">Œufs</option>
                <option value="céréale">Céréale</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            <div class="form-group form-group-small">
              <label class="form-label">Prix (€) <span class="required">*</span></label>
              <input type="number" name="produit_prix[]" class="form-input"
                     placeholder="3.50" min="0" step="0.01" required />
            </div>
            <div class="form-group form-group-small">
              <label class="form-label">Quantité <span class="required">*</span></label>
              <input type="number" name="produit_qte[]" class="form-input"
                     placeholder="50" min="0" step="0.5" required />
            </div>
          </div>
          <!-- Bouton supprimer : retire la ligne du DOM -->
          <button type="button" class="btn-remove-produit"
                  onclick="supprimerProduit('produit-row-${id}')"
                  aria-label="Supprimer ce produit">
            ✕
          </button>
        `;

        // On ajoute la nouvelle ligne dans le conteneur
        container.appendChild(div);
      }

      /**
       * supprimerProduit
       * -----------------
       * Retire une ligne produit du formulaire.
       * @param {string} rowId - L'id de la div à supprimer
       */
      function supprimerProduit(rowId) {
        const row = document.getElementById(rowId);
        if (row) {
          row.remove();
        }
      }
    </script>

  </body>
</html>
