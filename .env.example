# .env.example
# -------------
# Ce fichier est un modèle pour créer votre fichier .env
# Copiez-le : cp .env.example .env
# Puis remplissez les valeurs avec vos propres informations.
#
# ⚠️  Le fichier .env NE DOIT PAS être commité dans Git car il contient
#     des informations sensibles (mots de passe, clés secrètes).
#     Il est normalement listé dans .gitignore.

# Port sur lequel le serveur écoute
PORT=3000

# Environnement d'exécution (development ou production)
# En production, les cookies sont envoyés uniquement en HTTPS
NODE_ENV=development

# === Connexion à PostgreSQL (Supabase) ===
# Pour Supabase, récupérez ces valeurs dans Settings → Database → Connection String
# Format: postgres://[user]:[password]@[host]:[port]/[database]

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_postgres
DB_NAME=postgres

# Pour Supabase en production :
# DB_HOST=votre-projet.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=votre_mot_de_passe_supabase
# DB_NAME=postgres
# NODE_ENV=production

# Clé secrète pour les sessions Express
# Génère une clé aléatoire avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=remplacez_par_une_cle_aleatoire_longue
